FROM node:20-alpine AS builder

WORKDIR /app
COPY package*.json ./
RUN npm ci

COPY tsconfig*.json ./
COPY src/backend ./src/backend
RUN npm run build -- --project tsconfig.server.json 2>/dev/null || npx tsc --project tsconfig.server.json

FROM node:20-alpine

WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production

COPY --from=builder /app/dist/backend ./dist/backend

EXPOSE 3000
ENV NODE_ENV=production
CMD ["node", "dist/backend/server.js"]
